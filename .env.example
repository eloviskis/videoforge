# VideoForge - Variáveis de Ambiente
# Copie este arquivo para .env e preencha com suas credenciais

# === APIs de IA ===
# Google Gemini API (recomendado - grátis)
GEMINI_API_KEY=your_gemini_api_key_here
# Obter em: https://aistudio.google.com/apikey

# OpenAI (alternativa - pago)
OPENAI_API_KEY=your_openai_api_key_here

# Groq (alternativa - grátis com limites)
GROQ_API_KEY=your_groq_api_key_here

# === APIs de Imagens ===
# Pexels API (recomendado - grátis)
PEXELS_API_KEY=your_pexels_api_key_here
# Obter em: https://www.pexels.com/api/

# Pixabay API (alternativa)
PIXABAY_API_KEY=your_pixabay_api_key_here

# === YouTube ===
# Credenciais OAuth 2.0 (criadas no Google Cloud Console)
# Ver: https://console.cloud.google.com/
# Os arquivos client_secret.json e token.json serão salvos em /python-scripts/

# === PostgreSQL ===
POSTGRES_USER=videoforge
POSTGRES_PASSWORD=forge123
POSTGRES_DB=videoforge

# === n8n ===
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=videoforge2026

# === Configurações Opcionais ===
# ElevenLabs TTS (caso queira usar no futuro)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# TTS Voice padrão (Edge TTS)
DEFAULT_TTS_VOICE=pt-BR-AntonioNeural
