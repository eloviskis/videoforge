import { resolve, dirname } from 'path';
import { fileURLToPath } from 'url';
import fs from 'fs/promises';
import { exec } from 'child_process';
import { promisify } from 'util';

const execAsync = promisify(exec);
const __filename = fileURLToPath(import.meta.url);
const __dirname = dirname(__filename);
const MEDIA_DIR = resolve(__dirname, '..', '..', 'media');

// ========================================
// RENDERIZADOR DE VÍDEO ESTILO NEWS
// ========================================
export async function renderizarVideoNoticias(videoId, roteiro, audioPaths, visuais) {
  const dockerVideoPath = `/media/videos/news_${videoId}.mp4`;
  const hostVideoPath = resolve(MEDIA_DIR, 'videos', `news_${videoId}.mp4`);

  await fs.mkdir(resolve(MEDIA_DIR, 'videos'), { recursive: true });
  await fs.mkdir(resolve(MEDIA_DIR, 'temp', videoId), { recursive: true });

  // Salvar dados para o script Python
  const roteiroPath = resolve(MEDIA_DIR, 'temp', `${videoId}_news_roteiro.json`);
  const visuaisPath = resolve(MEDIA_DIR, 'temp', `${videoId}_news_visuais.json`);
  const duracoesPath = resolve(MEDIA_DIR, 'temp', `${videoId}_news_duracoes.json`);

  await fs.writeFile(roteiroPath, JSON.stringify(roteiro), 'utf-8');
  await fs.writeFile(visuaisPath, JSON.stringify(visuais), 'utf-8');

  // Durações do TTS - remover arquivo anterior (pode ser root do Docker)
  const duracoes = audioPaths.duracoes || [];
  try { await fs.unlink(duracoesPath); } catch (_) { /* não existe, ok */ }
  await fs.writeFile(duracoesPath, JSON.stringify(duracoes), 'utf-8');

  const scriptContent = NEWS_RENDER_SCRIPT;
  const scriptPath = resolve(MEDIA_DIR, 'temp', `${videoId}_news_render.py`);
  await fs.writeFile(scriptPath, scriptContent, 'utf-8');

  const dockerScriptPath = `/media/temp/${videoId}_news_render.py`;
  const dockerRoteiroPath = `/media/temp/${videoId}_news_roteiro.json`;
  const dockerVisuaisPath = `/media/temp/${videoId}_news_visuais.json`;
  const dockerDuracoesPath = `/media/temp/${videoId}_news_duracoes.json`;
  const dockerAudioPath = audioPaths.docker;

  const cmd = `docker exec videoforge-python-worker python ${dockerScriptPath} "${videoId}" "${dockerAudioPath}" "${dockerRoteiroPath}" "${dockerVisuaisPath}" "${dockerDuracoesPath}" "${dockerVideoPath}"`;

  try {
    const { stdout, stderr } = await execAsync(cmd, { timeout: 600000 });
    console.log('🎬 News render:', stdout.trim());

    await fs.access(hostVideoPath);
    const stats = await fs.stat(hostVideoPath);
    console.log(`✅ Vídeo news renderizado: ${hostVideoPath} (${(stats.size / 1024 / 1024).toFixed(1)}MB)`);
    return { docker: dockerVideoPath, host: hostVideoPath };
  } catch (error) {
    console.error('❌ Erro ao renderizar news:', error.message);
    if (error.stderr) console.error(error.stderr.slice(-2000));
    throw new Error(`Falha ao renderizar vídeo news: ${error.message}`);
  }
}

// ========================================
// SCRIPT PYTHON DE RENDERIZAÇÃO NEWS
// ========================================
const NEWS_RENDER_SCRIPT = `
import json, subprocess, os, requests, sys, math, textwrap, random

video_id = sys.argv[1]
audio_path = sys.argv[2]
roteiro_path = sys.argv[3]
visuais_path = sys.argv[4]
duracoes_path = sys.argv[5]
output_path = sys.argv[6]

roteiro = json.load(open(roteiro_path))
visuais = json.load(open(visuais_path))
duracoes = json.load(open(duracoes_path))

temp_dir = f'/media/temp/{video_id}'
os.makedirs(temp_dir, exist_ok=True)

# ================================================
# CORES DO TEMA NEWS
# ================================================
COR_BARRA_TOPO = '#1a1a2e'
COR_BARRA_LOWER = '#c0392b'
COR_ACCENT = '#e74c3c'
COR_TEXTO_BRANCO = '#ffffff'
COR_TEXTO_LIGHT = '#ecf0f1'
COR_FUNDO = '#0d0d1a'

# ================================================
# HELPERS
# ================================================
def download_image(url, path):
    raw_path = path + '_raw.jpg'
    try:
        r = requests.get(url, timeout=30, headers={'User-Agent': 'Mozilla/5.0'})
        r.raise_for_status()
        if len(r.content) < 5000:
            return False
        with open(raw_path, 'wb') as f:
            f.write(r.content)
        result = subprocess.run([
            'ffmpeg', '-y', '-i', raw_path,
            '-vf', 'scale=1920:1080:force_original_aspect_ratio=increase,crop=1920:1080',
            '-q:v', '2', path
        ], capture_output=True, timeout=30)
        try:
            os.remove(raw_path)
        except:
            pass
        return result.returncode == 0
    except Exception as e:
        print(f'  Download falhou ({url[:60]}...): {e}')
        return False

def escape_text(text):
    return text.replace("'", "'\\\\\\\\''").replace(":", "\\\\\\\\:").replace("%", "%%").replace('"', '\\\\\\\\\\\\\\\\"')

def gerar_fallback_image(path, cor=COR_FUNDO):
    subprocess.run([
        'ffmpeg', '-y', '-f', 'lavfi', '-i',
        f'color=c={cor}:s=1920x1080:d=1',
        '-frames:v', '1', '-q:v', '2', path
    ], capture_output=True, timeout=10)

# ================================================
# GERAR MUSICA DE FUNDO AMBIENT
# ================================================
def gerar_musica_fundo(duracao, path):
    """Gera uma trilha ambient suave com FFmpeg"""
    dur = int(duracao) + 5
    
    # Pad ambient com harmonics suaves
    filter_complex = (
        f"sine=frequency=110:duration={dur}:sample_rate=44100[bass];"
        f"sine=frequency=165:duration={dur}:sample_rate=44100[fifth];"
        f"sine=frequency=220:duration={dur}:sample_rate=44100[oct];"
        f"sine=frequency=277:duration={dur}:sample_rate=44100[third];"
        f"[bass]volume=0.12[b];"
        f"[fifth]volume=0.08[f];"
        f"[oct]volume=0.06[o];"
        f"[third]volume=0.04[t];"
        f"[b][f][o][t]amix=inputs=4:duration=longest[mix];"
        f"[mix]aecho=0.8:0.88:60:0.4,aecho=0.8:0.7:40:0.3[echo];"
        f"[echo]lowpass=f=600,highpass=f=60[filtered];"
        f"[filtered]afade=t=in:st=0:d=3,afade=t=out:st={dur-3}:d=3[out]"
    )
    
    result = subprocess.run([
        'ffmpeg', '-y',
        '-f', 'lavfi', '-i', f'anullsrc=r=44100:cl=stereo',
        '-filter_complex', filter_complex,
        '-map', '[out]',
        '-t', str(dur),
        '-c:a', 'libmp3lame', '-b:a', '128k',
        path
    ], capture_output=True, text=True, timeout=60)
    
    if result.returncode != 0:
        print(f'  Musica fallback (silencio)')
        # Gerar silêncio como fallback
        subprocess.run([
            'ffmpeg', '-y', '-f', 'lavfi', '-i',
            f'anullsrc=r=44100:cl=stereo',
            '-t', str(dur), '-c:a', 'libmp3lame', '-b:a', '128k', path
        ], capture_output=True, timeout=30)
    return os.path.exists(path)

# ================================================
# SLIDESHOW: gerar clip com múltiplas imagens
# ================================================
def gerar_slideshow_clip(imagens, duracao, overlays, clip_path):
    """
    Gera um clip slideshow com Ken Burns + crossfade entre imagens.
    overlays = lista de filtros drawtext/drawbox para aplicar por cima.
    Roda em 2 passes: 1) xfade slideshow, 2) overlays via -vf
    """
    n_imgs = len(imagens)
    if n_imgs == 0:
        return False
    
    dur = max(duracao, 3.0) + 0.8
    fade_out_t = max(dur - 0.5, 1.0)
    
    if n_imgs == 1:
        # Uma imagem só: Ken Burns zoom + overlays direto via -vf
        filters = [
            'scale=1920:1080:force_original_aspect_ratio=increase,crop=1920:1080',
            'setsar=1:1',
            f"zoompan=z='min(zoom+0.0008,1.08)':d={int(dur*25)}:s=1920x1080:fps=25",
        ]
        filters.extend(overlays)
        filters.append(f'fade=t=in:st=0:d=0.5,fade=t=out:st={fade_out_t}:d=0.5')
        
        cmd = [
            'ffmpeg', '-y',
            '-loop', '1', '-t', str(dur), '-i', imagens[0],
            '-vf', ','.join(filters),
            '-c:v', 'libx264', '-preset', 'fast', '-crf', '23',
            '-pix_fmt', 'yuv420p', '-r', '25', '-t', str(dur),
            clip_path
        ]
        result = subprocess.run(cmd, capture_output=True, text=True, timeout=180)
        return result.returncode == 0
    
    # === PASSO 1: Slideshow com xfade (sem overlays, pq # nas cores quebra filter_complex) ===
    seg_dur = dur / n_imgs
    raw_slide = clip_path + '_raw_slide.mp4'
    
    input_args = []
    for i, img in enumerate(imagens):
        input_args.extend(['-loop', '1', '-t', str(seg_dur + 1), '-i', img])
    
    zoom_directions = [
        "zoompan=z='min(zoom+0.001,1.10)':x='iw/2-(iw/zoom/2)':y='ih/2-(ih/zoom/2)':d={d}:s=1920x1080:fps=25",
        "zoompan=z='min(zoom+0.0008,1.08)':x='0':y='0':d={d}:s=1920x1080:fps=25",
        "zoompan=z='min(zoom+0.001,1.10)':x='iw-iw/zoom':y='ih-ih/zoom':d={d}:s=1920x1080:fps=25",
    ]
    
    filter_parts = []
    for i in range(n_imgs):
        d = int((seg_dur + 1) * 25)
        zoom_f = zoom_directions[i % len(zoom_directions)].format(d=d)
        filter_parts.append(
            f"[{i}:v]scale=1920:1080:force_original_aspect_ratio=increase,crop=1920:1080,"
            f"setsar=1:1,{zoom_f},trim=duration={seg_dur + 0.5},setpts=PTS-STARTPTS[v{i}]"
        )
    
    # xfade entre clips
    xfade_dur = 0.5
    if n_imgs == 2:
        offset = seg_dur - xfade_dur
        filter_parts.append(
            f"[v0][v1]xfade=transition=slideleft:duration={xfade_dur}:offset={max(offset, 0.1)}[merged]"
        )
    else:
        offset = seg_dur - xfade_dur
        filter_parts.append(
            f"[v0][v1]xfade=transition=slideleft:duration={xfade_dur}:offset={max(offset, 0.1)}[m01]"
        )
        for i in range(2, n_imgs):
            prev = f'm{i-2}{i-1}' if i > 2 else 'm01'
            new_offset = offset + (seg_dur - xfade_dur)
            offset = new_offset
            next_label = f'm{i-1}{i}' if i < n_imgs - 1 else 'merged'
            filter_parts.append(
                f"[{prev}][v{i}]xfade=transition=slideright:duration={xfade_dur}:offset={max(new_offset, 0.1)}[{next_label}]"
            )
    
    # Trim e fade (sem overlays - sem #)
    filter_parts.append(
        f"[merged]trim=duration={dur},setpts=PTS-STARTPTS,"
        f"fade=t=in:st=0:d=0.5,fade=t=out:st={fade_out_t}:d=0.5[final]"
    )
    
    filter_complex = ';'.join(filter_parts)
    
    cmd1 = [
        'ffmpeg', '-y',
        *input_args,
        '-filter_complex', filter_complex,
        '-map', '[final]',
        '-c:v', 'libx264', '-preset', 'fast', '-crf', '21',
        '-pix_fmt', 'yuv420p', '-r', '25', '-t', str(dur),
        raw_slide
    ]
    result = subprocess.run(cmd1, capture_output=True, text=True, timeout=180)
    if result.returncode != 0:
        print(f'  Slideshow xfade erro: {result.stderr[-300:]}')
        # Fallback: usar só a primeira imagem
        return gerar_slideshow_clip([imagens[0]], duracao, overlays, clip_path)
    
    # === PASSO 2: Aplicar overlays via -vf (onde # nas cores funciona normalmente) ===
    if overlays:
        overlay_filters = ','.join(overlays)
        cmd2 = [
            'ffmpeg', '-y',
            '-i', raw_slide,
            '-vf', overlay_filters,
            '-c:v', 'libx264', '-preset', 'fast', '-crf', '23',
            '-pix_fmt', 'yuv420p', '-r', '25',
            clip_path
        ]
        result2 = subprocess.run(cmd2, capture_output=True, text=True, timeout=120)
        try:
            os.remove(raw_slide)
        except:
            pass
        if result2.returncode != 0:
            print(f'  Overlay erro: {result2.stderr[-300:]}')
            # Usar slideshow sem overlays
            try:
                os.rename(raw_slide, clip_path)
            except:
                pass
            return os.path.exists(clip_path)
        return True
    else:
        try:
            os.rename(raw_slide, clip_path)
        except:
            pass
        return os.path.exists(clip_path)

# ================================================
# DOWNLOAD DE TODAS AS IMAGENS
# ================================================
print('=== BAIXANDO IMAGENS ===')
imagens_map = {}
for i, v in enumerate(visuais):
    urls = v.get('urls', [])
    # Compat com formato antigo (campo url)
    if not urls and v.get('url'):
        urls = [v['url']]
    
    downloaded = []
    for j, url in enumerate(urls):
        img_path = f'{temp_dir}/news_img_{i}_{j}.jpg'
        if url and download_image(url, img_path):
            downloaded.append(img_path)
        else:
            # Fallback: imagem de cor sólida
            gerar_fallback_image(img_path)
            downloaded.append(img_path)
    
    if not downloaded:
        fb_path = f'{temp_dir}/news_img_{i}_fb.jpg'
        gerar_fallback_image(fb_path)
        downloaded.append(fb_path)
    
    imagens_map[i] = downloaded
    print(f'  Visual {i+1}/{len(visuais)}: {len(downloaded)} imgs ({v.get("tipo", "?")})')

# ================================================
# GERAR MUSICA DE FUNDO
# ================================================
print('=== GERANDO MUSICA DE FUNDO ===')
total_duracao = sum(duracoes) + len(duracoes) * 0.8 + 5
musica_path = f'{temp_dir}/news_bgm.mp3'
gerar_musica_fundo(total_duracao, musica_path)
print(f'  Musica: {total_duracao:.0f}s gerada')

# ================================================
# RENDERIZAR CLIPS
# ================================================
print('=== RENDERIZANDO CLIPS ===')
clips = []
total_noticias = len(roteiro.get('noticias', []))
duracao_idx = 0

# --- ABERTURA ---
abertura_dur = duracoes[duracao_idx] if duracao_idx < len(duracoes) else 10.0
abertura_clip = f'{temp_dir}/clip_abertura.mp4'
titulo = escape_text(roteiro.get('titulo', 'Resumo do Dia'))
abertura_overlays = [
    f"eq=brightness=-0.15:saturation=0.9",
    f"drawbox=x=0:y=ih/2-130:w=iw:h=260:color={COR_BARRA_TOPO}@0.85:t=fill",
    f"drawbox=x=0:y=ih/2-130:w=iw:h=6:color={COR_ACCENT}:t=fill",
    f"drawbox=x=0:y=ih/2+124:w=iw:h=6:color={COR_ACCENT}:t=fill",
    f"drawtext=text='{titulo}':fontcolor=white:fontsize=48:"
    f"x=(w-text_w)/2:y=(h-text_h)/2-25:"
    f"font=DejaVu Sans:borderw=2:bordercolor=black:"
    f"enable='gte(t,0.3)'",
    f"drawtext=text='COMPILACAO DE NOTICIAS':fontcolor={COR_TEXTO_LIGHT}:fontsize=26:"
    f"x=(w-text_w)/2:y=(h/2)+35:"
    f"font=DejaVu Sans:borderw=1:bordercolor=black:"
    f"enable='gte(t,0.6)'",
]
if gerar_slideshow_clip(imagens_map[0], abertura_dur, abertura_overlays, abertura_clip):
    clips.append(abertura_clip)
    print(f'  Abertura: {abertura_dur:.1f}s OK ({len(imagens_map[0])} imgs)')
duracao_idx += 1

# --- NOTÍCIAS ---
for i, noticia in enumerate(roteiro.get('noticias', [])):
    dur = duracoes[duracao_idx] if duracao_idx < len(duracoes) else 15.0
    clip_path = f'{temp_dir}/clip_news_{i+1}.mp4'
    img_idx = i + 1
    imgs = imagens_map.get(img_idx, imagens_map.get(0))

    manchete = escape_text(noticia.get('manchete', f'Noticia {i+1}')[:80])
    fonte = escape_text(noticia.get('fonte', 'Fonte')[:40])
    numero_text = escape_text(f'#{i+1} de {total_noticias}')

    news_overlays = [
        # Lower third - barra principal vermelha
        f"drawbox=x=0:y=ih-180:w=iw:h=100:color={COR_BARRA_LOWER}@0.92:t=fill:"
        f"enable='gte(t,0.4)'",
        # Barra fonte abaixo
        f"drawbox=x=0:y=ih-80:w=iw:h=80:color={COR_BARRA_TOPO}@0.88:t=fill:"
        f"enable='gte(t,0.4)'",
        # Manchete
        f"drawtext=text='{manchete}':fontcolor=white:fontsize=36:"
        f"x=180:y=ih-168:"
        f"font=DejaVu Sans Bold:borderw=1:bordercolor=black:"
        f"enable='gte(t,0.5)'",
        # Fonte
        f"drawtext=text='Fonte\\\\\\\\: {fonte}':fontcolor={COR_TEXTO_LIGHT}:fontsize=22:"
        f"x=180:y=ih-58:"
        f"font=DejaVu Sans:borderw=1:bordercolor=black:"
        f"enable='gte(t,0.5)'",
        # Badge top-right
        f"drawbox=x=iw-160:y=20:w=140:h=55:color={COR_ACCENT}@0.9:t=fill:"
        f"enable='gte(t,0.3)'",
        f"drawtext=text='{numero_text}':fontcolor=white:fontsize=24:"
        f"x=iw-148:y=36:"
        f"font=DejaVu Sans Bold:"
        f"enable='gte(t,0.3)'",
        # Branding topo
        f"drawbox=x=0:y=0:w=iw:h=52:color={COR_BARRA_TOPO}@0.8:t=fill",
        f"drawtext=text='NOTICIAS DO DIA':fontcolor={COR_TEXTO_LIGHT}:fontsize=20:"
        f"x=30:y=14:"
        f"font=DejaVu Sans Bold",
    ]

    if gerar_slideshow_clip(imgs, dur, news_overlays, clip_path):
        clips.append(clip_path)
        print(f'  Noticia {i+1}/{total_noticias}: {dur:.1f}s OK ({len(imgs)} imgs)')
    else:
        print(f'  Noticia {i+1}/{total_noticias}: FALHOU')
    duracao_idx += 1

# --- ENCERRAMENTO ---
enc_dur = duracoes[duracao_idx] if duracao_idx < len(duracoes) else 10.0
enc_img_idx = len(visuais) - 1
enc_clip = f'{temp_dir}/clip_encerramento.mp4'
texto_obrigado = escape_text('Obrigado por assistir!')
cta_text = escape_text('INSCREVA-SE e ATIVE o sino!')
enc_overlays = [
    f"eq=brightness=-0.2:saturation=0.8",
    f"drawbox=x=0:y=ih/2-150:w=iw:h=300:color={COR_BARRA_TOPO}@0.85:t=fill",
    f"drawbox=x=0:y=ih/2-150:w=iw:h=6:color={COR_ACCENT}:t=fill",
    f"drawbox=x=0:y=ih/2+144:w=iw:h=6:color={COR_ACCENT}:t=fill",
    f"drawtext=text='{texto_obrigado}':fontcolor=white:fontsize=52:"
    f"x=(w-text_w)/2:y=(h-text_h)/2-40:"
    f"font=DejaVu Sans Bold:borderw=2:bordercolor=black:"
    f"enable='gte(t,0.3)'",
    f"drawtext=text='{cta_text}':fontcolor={COR_TEXTO_LIGHT}:fontsize=32:"
    f"x=(w-text_w)/2:y=(h/2)+30:"
    f"font=DejaVu Sans:borderw=1:bordercolor=black:"
    f"enable='gte(t,0.8)'",
]
if gerar_slideshow_clip(imagens_map.get(enc_img_idx, imagens_map.get(0)), enc_dur, enc_overlays, enc_clip):
    clips.append(enc_clip)
    print(f'  Encerramento: {enc_dur:.1f}s OK')

if not clips:
    print('ERRO: Nenhum clip renderizado')
    sys.exit(1)

print(f'=== CONCATENANDO {len(clips)} CLIPS ===')

# Concat
concat_list = f'{temp_dir}/news_clips_list.txt'
with open(concat_list, 'w') as f:
    for c in clips:
        f.write(f"file '{c}'\\n")

concat_video = f'{temp_dir}/news_concat.mp4'
result = subprocess.run([
    'ffmpeg', '-y', '-f', 'concat', '-safe', '0', '-i', concat_list,
    '-c', 'copy', concat_video
], capture_output=True, text=True, timeout=300)

if result.returncode != 0:
    print(f'Concat erro: {result.stderr[-500:]}')
    sys.exit(1)

# Mesclar com áudio de narração + música de fundo
print('=== MIXANDO AUDIO (narracao + musica) ===')

# Primeiro mixar narração com música de fundo
mixed_audio = f'{temp_dir}/news_audio_mixed.mp3'
result = subprocess.run([
    'ffmpeg', '-y',
    '-i', audio_path,
    '-i', musica_path,
    '-filter_complex',
    '[1:a]volume=0.12[bgm];'
    '[0:a][bgm]amix=inputs=2:duration=first:dropout_transition=3[out]',
    '-map', '[out]',
    '-c:a', 'libmp3lame', '-b:a', '192k',
    mixed_audio
], capture_output=True, text=True, timeout=120)

if result.returncode != 0:
    print(f'Mix audio falhou, usando narracao pura: {result.stderr[-300:]}')
    mixed_audio = audio_path

# Juntar vídeo + áudio mixado
print('=== FINALIZANDO VIDEO ===')
result = subprocess.run([
    'ffmpeg', '-y',
    '-i', concat_video, '-i', mixed_audio,
    '-c:v', 'copy', '-c:a', 'aac', '-b:a', '192k',
    '-shortest', '-movflags', '+faststart',
    output_path
], capture_output=True, text=True, timeout=300)

if result.returncode != 0:
    print(f'FFmpeg final stderr: {result.stderr[-1000:]}')
    sys.exit(1)

# Corrigir permissoes
for root_dir, dirs, files in os.walk(temp_dir):
    for fname in files:
        try:
            os.chmod(os.path.join(root_dir, fname), 0o666)
        except:
            pass
try:
    os.chmod(output_path, 0o666)
except:
    pass

size = os.path.getsize(output_path)
print(f'Video news pronto: {output_path} ({size // 1024 // 1024}MB)')
`;
