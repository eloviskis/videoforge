# Variáveis de ambiente - PRODUÇÃO
# Copie este arquivo para .env.production e preencha

# ============================================
# DOMÍNIO (obrigatório)
# ============================================
DOMAIN=seudominio.com.br

# ============================================
# APIs (mesmo do local)
# ============================================
GEMINI_API_KEY=sua_chave_gemini
PEXELS_API_KEY=sua_chave_pexels

# YouTube
YOUTUBE_CLIENT_ID=seu_client_id
YOUTUBE_CLIENT_SECRET=seu_secret
YOUTUBE_REDIRECT_URI=https://seudominio.com.br/api/youtube/callback

# ============================================
# REDES SOCIAIS
# ============================================
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_REDIRECT_URI=https://seudominio.com.br/api/social/twitter/callback

FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=https://seudominio.com.br/api/social/facebook/callback

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=https://seudominio.com.br/api/social/linkedin/callback

# ============================================
# BANCO DE DADOS & SENHAS
# ============================================
DB_PASSWORD=forge_TROQUE_ESTA_SENHA_123
DB_N8N_PASSWORD=n8n_TROQUE_ESTA_SENHA_456
REDIS_PASSWORD=redis_TROQUE_ESTA_SENHA_789
N8N_USER=admin
N8N_PASSWORD=TROQUE_ESTA_SENHA_n8n

