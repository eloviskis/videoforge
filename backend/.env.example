# Variáveis de ambiente do VideoForge

# Google Gemini API (obrigatório)
GEMINI_API_KEY=sua_chave_aqui

# Pexels API (obrigatório)
PEXELS_API_KEY=sua_chave_aqui

# YouTube API (para publicação automática)
YOUTUBE_CLIENT_ID=seu_client_id_aqui
YOUTUBE_CLIENT_SECRET=seu_client_secret_aqui
YOUTUBE_REDIRECT_URI=http://localhost:3001/api/youtube/callback

# Configurações gerais
PORT=3001
N8N_URL=http://localhost:5678
