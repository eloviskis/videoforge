{
  "name": "videoforge-desktop",
  "version": "1.2.0",
  "description": "VideoForge - Criação automática de vídeos com IA",
  "main": "main.js",
  "author": "VideoForge",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SEU_USUARIO/videoforge"
  },
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "build:linux": "electron-builder --linux",
    "build:win": "electron-builder --win",
    "build:all": "electron-builder --linux --win"
  },
  "build": {
    "appId": "com.videoforge.desktop",
    "productName": "VideoForge",
    "copyright": "Copyright © 2026 VideoForge",
    "directories": {
      "output": "../dist-desktop"
    },
    "files": [
      "main.js",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "backend-bundle",
        "to": "app-data/backend",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../media",
        "to": "app-data/media",
        "filter": [
          "!**/*.mp4",
          "!**/*.mp3"
        ]
      },
      {
        "from": "../database",
        "to": "app-data/database"
      },
      {
        "from": "../docker-compose.yml",
        "to": "app-data/docker-compose.yml"
      },
      {
        "from": "../python-worker",
        "to": "app-data/python-worker"
      }
    ],
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "category": "Video",
      "maintainer": "VideoForge",
      "synopsis": "Criação automática de vídeos com IA"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "forceCodeSigning": false,
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "VideoForge"
    },
    "publish": {
      "provider": "github",
      "owner": "SEU_USUARIO",
      "repo": "videoforge",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "electron-is-dev": "^3.0.1",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": "^40.4.0",
    "electron-builder": "^26.7.0"
  }
}
